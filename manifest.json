{
  "manifest_version": 3,
  "name": "QuickCopy",
  "version": "2.0",
  "description": "Instant access to your saved snippets — click or search to copy anywhere on the web.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "features/utils.js",
        "storage/presets.js",
        "features/snippets.js",
        "features/dragInsert.js",
        "ui/styles.js",
        "ui/components.js",
        "ui/configPanel.js",
        "ui/commandPalette.js",
        "ui/floatingMenu.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
